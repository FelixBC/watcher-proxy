<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Fast watchdog (layer 1). Restart-on-death is now the WinConfig Windows Service's job, not this task's own RestartOnFailure policy - see InstallWatcherService.ps1.</Description>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
      <Delay>PT15S</Delay>
    </LogonTrigger>
  </Triggers>
  <Principals>
    <!-- GroupId = BUILTIN\Users (well-known SID S-1-5-32-545), NOT a specific
         UserId. Confirmed by hand this session: leaving Principal's user
         unspecified doesn't mean "any logged-in user" - Task Scheduler
         auto-bakes in the SID of whoever ran the install, so on a PC with
         a separate admin (installer) and worker account, the task would be
         bound to the admin and could fail to start during the worker's own
         session. Binding to the Users group instead makes it fire correctly
         for whichever account actually logs on. -->
    <Principal id="Author">
      <GroupId>S-1-5-32-545</GroupId>
      <RunLevel>LeastPrivilege</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <IdleSettings>
      <StopOnIdleEnd>false</StopOnIdleEnd>
      <RestartOnIdle>false</RestartOnIdle>
    </IdleSettings>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <RunOnlyIfIdle>false</RunOnlyIfIdle>
    <WakeToRun>false</WakeToRun>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <Priority>7</Priority>
  </Settings>
  <Actions Context="Author">
    <!-- Launch through wscript + a VBS so the watchdog's PowerShell is created
         hidden from the start. A task action of "powershell.exe -WindowStyle
         Hidden" flashes a console window in a real interactive logon (it hides
         itself only AFTER the console appears) - that was one of the visible
         black windows reported on real hardware. RunWatchdogLoopHidden.vbs
         starts WatchdogLoop.ps1 with WshShell.Run intWindowStyle = 0 (no flash).
         The wscript action returns immediately; the detached WatchdogLoop.ps1
         is the persistent process (it self-guards against duplicates). -->
    <Exec>
      <Command>wscript.exe</Command>
      <Arguments>"__BRAIN_DIR__\RunWatchdogLoopHidden.vbs"</Arguments>
    </Exec>
  </Actions>
</Task>
